rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isAuthenticated() && getUserData().approved == true && getUserData().disabled != true;
    }

    function isAdmin() {
      return isApproved() && getUserData().role == 'admin';
    }

    function isHost() {
      return isApproved() && getUserData().role == 'host';
    }

    function isPrivileged() {
      return isAdmin() || isHost();
    }

    function canUserReadEvent() {
      return resource.data.creatorId == request.auth.uid ||
        resource.data.createdById == request.auth.uid ||
        resource.data.createdByRole in ['host', 'admin'];
    }

    function canUserReadEventComments(eventId) {
      let event = getEventData(eventId);
      return event.creatorId == request.auth.uid ||
        event.createdById == request.auth.uid ||
        event.createdByRole in ['host', 'admin'];
    }

    function getEventData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isPrivileged() ||
        (isApproved() && resource.data.role in ['admin', 'host'])
      );
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == 'user'
        && request.resource.data.approved == false
        && request.resource.data.disabled == false;
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'approved', 'disabled'])) ||
        isPrivileged()
      );
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && request.resource.data.createdById == request.auth.uid
        && request.resource.data.createdByRole == getUserData().role;
      allow update, delete: if isApproved() && (
        isPrivileged() || resource.data.creatorId == request.auth.uid
      );
    }

    match /comments/{commentId} {
      allow read: if isApproved();
      allow create: if isApproved() && isPrivileged();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isApproved()
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.read == false
        && (!('type' in request.resource.data) || request.resource.data.type is string)
        && (!('eventId' in request.resource.data) || request.resource.data.eventId is string);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
